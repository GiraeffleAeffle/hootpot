# Hootpot public configuration.
# Anything that ships to the client must be prefixed NEXT_PUBLIC_.
# The miniapp SDK itself needs no configuration; the host injects the wallet.

# Circles group URL where users can select Hootpot as an affiliate group.
NEXT_PUBLIC_HOOTPOT_GROUP_URL=

# Operational pot/org/Safe recipient for CRC top-ups.
NEXT_PUBLIC_HOOTPOT_POT_ADDRESS=

# Optional on-chain receipt/draw registry contract.
NEXT_PUBLIC_HOOTPOT_REGISTRY_ADDRESS=
NEXT_PUBLIC_HOOTPOT_POOL_ADDRESS=
NEXT_PUBLIC_HOOTPOT_MERCHANT_REGISTRY_ADDRESS=

# Optional verified merchant checkout recipients.
NEXT_PUBLIC_HOOTPOT_MERCHANT_ONE=
NEXT_PUBLIC_HOOTPOT_MERCHANT_TWO=
NEXT_PUBLIC_HOOTPOT_MERCHANT_THREE=

# Server-side RPC used to verify submitted Gnosis Chain transaction hashes.
# Defaults to https://rpc.gnosischain.com/ when empty.
GNOSIS_RPC_URL=

# Optional override for the Gnosis Pay API base URL.
# Defaults to https://api.gnosispay.com when empty.
GNOSIS_PAY_API_BASE_URL=

# Optional override/cache for signed Gnosis Pay webhooks.
# If no public key is set, Hootpot fetches it from the public key URL.
GNOSIS_PAY_WEBHOOK_PUBLIC_KEY=
GNOSIS_PAY_WEBHOOK_PUBLIC_KEY_URL=
GNOSIS_PAY_WEBHOOK_MAX_SKEW_SECONDS=

# Required in production for operator-only mutations: draw, payout record, clear.
HOOTPOT_ADMIN_SECRET=

# Durable ledger storage. When empty, Hootpot falls back to local/tmp file storage.
KV_REST_API_URL=
KV_REST_API_TOKEN=
HOOTPOT_LEDGER_KEY=

# Contract deployment. Keep private keys out of committed env files.
HOOTPOT_OWNER=
PRIVATE_KEY=
